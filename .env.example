POSTGRES_USER=sirp
POSTGRES_PASSWORD=sirp
POSTGRES_DB=sirp
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Redis AUTH (requirepass). Must match the password embedded in REDIS_URL below.
REDIS_PASSWORD=sirp
# Format: redis://:<password>@host:port/db — URL-encode special characters in the password (e.g. @ → %40).
REDIS_URL=redis://:sirp@redis:6379/0
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# Elasticsearch: user is always `elastic`. Password must match ELASTIC_PASSWORD and appear in URLs (URL-encode if it contains @ : # etc.).
ELASTIC_PASSWORD=sirp
ELASTICSEARCH_URL=http://elastic:sirp@elasticsearch:9200
ALERT_SERVICE_URL=http://alert-service:8001
CASE_SERVICE_URL=http://case-service:8001
# case-service: evidence files directory (Dockerfile default /home/appuser/data/case-evidence when using compose volume)
# CASE_EVIDENCE_DIR=/tmp/sirp-case-evidence
# Max single file bytes (case-service); gateway allows up to MAX_CASE_EVIDENCE_BYTES for multipart upload
# CASE_EVIDENCE_MAX_BYTES=26214400
# MAX_CASE_EVIDENCE_BYTES=33554432
OBSERVABLE_SERVICE_URL=http://observable-service:8001
AUTOMATION_SERVICE_URL=http://automation-service:8001
NOTIFICATION_SERVICE_URL=http://notification-service:8001
SECRET_SERVICE_URL=http://secret-service:8001
# Next.js rewrites browser /sirp-api/* → this URL (Docker service name). Required for frontend container + API routes.
API_GATEWAY_URL=http://api-gateway:8000
# Frontend session cookie (sirp_token): must be false when users open the UI over http:// (e.g. :3000 on LAN). Set true only behind HTTPS to the browser.
COOKIE_SECURE=false
# Leave empty if you only use /auth/login (HS256). If set, only RS256 tokens trigger JWKS fetch.
KEYCLOAK_ISSUER=
KEYCLOAK_AUDIENCE=sirp-api
KEYCLOAK_CLIENT_ID=sirp-frontend
KEYCLOAK_CLIENT_SECRET=
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_me_now
APP_AUTH_JWT_SECRET=change_this_to_long_random_secret
# Required for POST /ingest/* on the API gateway (Wazuh integrator passes this as x-webhook-token). Use a long random string in production.
INBOUND_WEBHOOK_TOKEN=sirp-ingest-dev-change-me
# Must be identical for every service (gateway, alert-service, case-service, secret-service, observable, automation, notification).
INTERNAL_SERVICE_TOKEN=sirp-internal-dev-change-me
# Dev-only escape hatches (never enable in production):
# ALLOW_INSECURE_NO_INTERNAL_TOKEN=1
# ALLOW_INGEST_WITHOUT_TOKEN=1
DATA_ENCRYPTION_KEY=9pc95JNaPykspfJ-GFBzf8d3crUxVLUehbhyGv3lE1Y=
VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root
VAULT_SECRET_PATH=secret/data/sirp
# Browser WebSocket: same host/port as the Next.js UI (default 3000). server.js proxies /stream/events → API_GATEWAY_URL with Cookie auth.
# Override only if you terminate WS on another URL (e.g. shared ingress).
NEXT_PUBLIC_WS_URL=
# Browser link to OpenCTI UI. Must be reachable from users' browsers (rebuild frontend after change).
NEXT_PUBLIC_OPENCTI_URL=http://localhost:8080
# Optional if your OpenCTI version uses a different global search route or query name:
# NEXT_PUBLIC_OPENCTI_SEARCH_PATH=dashboard/search/knowledge/global
# NEXT_PUBLIC_OPENCTI_SEARCH_QUERY_PARAM=keyword
# IPs allowed to send SIEM webhooks. With ingest via api-gateway, list the Wazuh (or proxy) client IP;
# gateway forwards that IP when INTERNAL_SERVICE_TOKEN is set (see alert-service _ingest_client_ip).
INGEST_ALLOWLIST=127.0.0.1/32,10.0.0.0/8
WAZUH_URL=https://wazuh:55000
WAZUH_USER=foo
WAZUH_PASSWORD=bar
ELASTIC_SIEM_URL=http://elastic:sirp@elasticsearch:9200
ELASTIC_SIEM_API_KEY=
ELASTIC_SIEM_INDEX=.siem-signals-*
SPLUNK_URL=https://splunk:8089
SPLUNK_TOKEN=
SPLUNK_SAVED_SEARCH=SOC Alerts
SPLUNK_HEC_TOKEN=
SENTINEL_TENANT_ID=
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=
SENTINEL_SUBSCRIPTION_ID=
SENTINEL_RESOURCE_GROUP=
SENTINEL_WORKSPACE=
OPENCTI_URL=http://opencti:8080
# Personal access token (Profile → API); raw UUID only, no "Bearer ". If set here, it overrides the same key in secret-service DB.
OPENCTI_TOKEN=
OPENCTI_API_KEY=
# Optional if no token: platform user login (mutation token) — cached ~10 min in alert-service.
OPENCTI_USER=
OPENCTI_PASSWORD=
OPENCTI_QUERY_LIMIT=100
OPENCTI_AUTO_SYNC_ENABLED=false
OPENCTI_AUTO_SYNC_INTERVAL_SECONDS=300
# When auto-sync is on: pull threat intel from opencti, abuseipdb blacklist, or both (default opencti).
THREAT_INTEL_PULL_SOURCE=opencti
# AbuseIPDB (https://www.abuseipdb.com/) — IP check + optional blacklist ingest. Env overrides secret-service.
ABUSEIPDB_API_KEY=
# Optional API root (default https://api.abuseipdb.com/api/v2)
# ABUSEIPDB_API_BASE=https://api.abuseipdb.com/api/v2
ABUSEIPDB_BLACKLIST_LIMIT=100
ABUSEIPDB_CONFIDENCE_MINIMUM=90
# alert-service only: verbose OpenCTI traces (logger sirp.opencti). Never logs token values.
OPENCTI_DEBUG_LOG=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFY_EMAIL_TO=
SLACK_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=
FIREWALL_API_URL=
FIREWALL_API_TOKEN=
EDR_API_URL=
EDR_API_TOKEN=
WAZUH_ACTIVE_RESPONSE_URL=
WAZUH_ACTIVE_RESPONSE_TOKEN=
